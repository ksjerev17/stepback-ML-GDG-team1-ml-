# Step Back ML — 환경 변수 템플릿 (v9.6)
# 실제 .env는 절대 git에 커밋 X (§0.2, §13.1)

# ── Gemini (최종 산출물은 실 Gemini 사용) ──────────────────────
# 운영(GCP): 실제 키 입력 + FORCE_MOCK=false  → 실 Gemini.
# 로컬 개발/CI: 키 비우고 FORCE_MOCK=true       → Mock(자동 폴백, 전 기능 동작).
# 안전망: FORCE_MOCK=false 라도 키가 없거나 호출 실패하면 자동 Mock 폴백 → 서비스 안 죽음.
GEMINI_API_KEY=

# 감사 로그 user_id 해시 salt — 32자 이상 (배포 시 반드시 교체)
AUDIT_SALT=replace_me_with_32_plus_random_hex_chars

# 운영(실 Gemini): false  /  로컬·CI(Mock): true
FORCE_MOCK=true

# ── 서버 바인딩 ────────────────────────────────────────────────
# 로컬: 127.0.0.1. GCP/외부 배포: 0.0.0.0 (deploy_mode=true 권장)
ML_HOST=127.0.0.1
ML_PORT=8001

# ── v9.6: BE / DB 연동 (실 서버) ───────────────────────────────
# BE(Spring Boot) + DB(PostgreSQL) 호스트. ML은 BE를 직접 호출하지 않지만
# CORS 허용·헬스 표기·문서화를 위해 보관.
BE_HOST=119.201.125.216
BE_PORT=8080
DB_HOST=119.201.125.216
DB_PORT=5432

# ML을 GCP 등 외부에 띄울 때 true → 0.0.0.0 바인딩 안내 + BE 출처 CORS 자동 허용.
DEPLOY_MODE=false

# 추가 CORS 출처 (콤마 구분). 예: https://app.stepback.kr,https://stepback.kr
EXTRA_CORS_ORIGINS=

# 관리자 토큰 (quota reset 등). 로컬 기본 dev_token_local.
ADMIN_TOKEN=dev_token_local
